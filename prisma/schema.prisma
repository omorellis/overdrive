generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Cliente {
  id        String      @id @default(uuid())
  nome      String
  telefone  String?
  whatsapp  String?
  motos     String?     
  createdAt DateTime    @default(now())
  orcamentos Orcamento[]
  ordens     OrdemServico[] // Relação nova: Um cliente pode ter várias OS
}

model ServicoProduto {
  id        String   @id @default(uuid())
  tipo      String   
  nome      String
  preco     Float
  createdAt DateTime @default(now())
}

model Orcamento {
  id          String   @id @default(uuid())
  clienteId   String
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  tipo        String   
  total       Float
  itens       String   
  createdAt   DateTime @default(now())
}

model PinagemPainel {
  id          String   @id @default(uuid())
  marca       String
  moto        String
  anoInicio   Int
  anoFim      Int
  pinos       String   
  createdAt   DateTime @default(now())
}

// --- NOVOS MÓDULOS ABAIXO ---

model ProdutoEstoque {
  id          String   @id @default(uuid())
  codigo      String?  // Ex: LED-SMD-BRANCO
  nome        String
  categoria   String   // Ex: LED, Display, Motor de Passo, Outros
  quantidade  Int      @default(0)
  precoCusto  Float?
  precoVenda  Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OrdemServico {
  id          String   @id @default(uuid())
  clienteId   String
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  equipamento String   // Ex: Painel Yamaha Fazer 250
  defeito     String   // Reclamação/Relato do cliente
  status      String   @default("AGUARDANDO") // AGUARDANDO, BANCADA, PEÇA, FINALIZADO, ENTREGUE
  valorTotal  Float?
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Configuracao {
  id           String @id
  nomeOficina  String
  telefone     String
  instagram    String
  endereco     String
  cidadeEstado String
}

model Usuario {
  id    String @id @default(uuid())
  login String @unique
  senha String
}